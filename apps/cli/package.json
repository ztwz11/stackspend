{
  "name": "@stackspend/cli",
  "version": "0.1.0-alpha.0",
  "description": "Local-first cloud/SaaS usage, status, and expected billing CLI for StackSpend.",
  "private": false,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "bin": {
    "stackspend": "dist/apps/cli/src/index.js"
  },
  "main": "dist/apps/cli/src/cli.js",
  "types": "dist/apps/cli/src/cli.d.ts",
  "exports": {
    ".": {
      "types": "./dist/apps/cli/src/cli.d.ts",
      "import": "./dist/apps/cli/src/cli.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/apps/cli/src/**/*.js",
    "dist/apps/cli/src/**/*.d.ts",
    "dist/packages/**/*.js",
    "dist/packages/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "node ../../tools/scripts/build-cli.mjs",
    "prepack": "node ../../tools/scripts/build-cli.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  }
}
