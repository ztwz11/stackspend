{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MoneySiren Tray",
  "version": "0.1.0-alpha.12",
  "identifier": "dev.moneysiren.tray",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "assets"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MoneySiren",
        "url": "http://127.0.0.1:3000/ko/dashboard/overview",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "nsis"],
    "category": "DeveloperTool",
    "shortDescription": "Local MoneySiren tray notifier",
    "longDescription": "MoneySiren Tray is a local-only desktop tray notifier that reads sanitized loopback MoneySiren API responses.",
    "icon": [
      "icons/tray.ico",
      "icons/tray.png"
    ]
  }
}
