{
  "name": "@moneysiren/tray",
  "version": "0.1.0-alpha.5",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "icons:generate": "node ../../tools/scripts/generate-tray-icons.mjs",
    "native:check": "node ../../tools/scripts/check-tray-native.mjs",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "tauri:dev": "node ../../tools/scripts/run-tray-tauri.mjs dev",
    "tauri:build": "node ../../tools/scripts/run-tray-tauri.mjs build",
    "tauri:build:unsigned": "node ../../tools/scripts/run-tray-tauri.mjs build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.2"
  }
}
