# MoneySiren v0.1 uses env-only secrets.
# Never commit real API keys, tokens, webhook URLs, or provider identifiers.
# Keep secret values blank here. Export real values only in your shell for one run.

AWS_PROFILE=
OPENAI_ADMIN_KEY=
SUPABASE_ACCESS_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_IDS=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
CLOUDSDK_CONFIG=
MONEYSIREN_CODEX_CLI_USAGE=
MONEYSIREN_CLAUDE_CLI_USAGE=
# Optional Codex reset-credit expiry lookup. This uses an undocumented ChatGPT internal API.
CODEX_AUTH_FILE=
CODEX_HOME=
CODEX_RESET_CREDIT_ENDPOINT=https://chatgpt.com/backend-api/wham/rate-limit-reset-credits
CODEX_API_TIMEOUT_MS=15000
APP_TIME_ZONE=Asia/Seoul
RESET_CREDIT_API_KEY=
CRON_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional local CLI quota estimates. Non-secret token limits used when CLI logs do not expose quota percent.
MONEYSIREN_CODEX_FIVE_HOUR_TOKEN_LIMIT=
MONEYSIREN_CODEX_WEEKLY_TOKEN_LIMIT=
MONEYSIREN_CLAUDE_FIVE_HOUR_TOKEN_LIMIT=
MONEYSIREN_CLAUDE_WEEKLY_TOKEN_LIMIT=
SLACK_WEBHOOK_URL=
MONEYSIREN_DB_PATH=.moneysiren/moneysiren.sqlite
# Optional fallback when Node SQLite is unavailable.
MONEYSIREN_SQLITE_BIN=
MONEYSIREN_TIMEZONE=

# Optional local web credential store.
# Leave secrets blank in this example. Prefer OS keychain; use vault only for local runs where keychain is unavailable.
MONEYSIREN_CREDENTIAL_BACKEND=
MONEYSIREN_CREDENTIAL_VAULT_PATH=
MONEYSIREN_CREDENTIAL_VAULT_PASSPHRASE=

# Optional local OAuth broker settings. Client IDs and endpoints are operator-local config, not provider secrets.
SUPABASE_OAUTH_AUTHORIZATION_URL=
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_TOKEN_URL=
SUPABASE_OAUTH_CLIENT_SECRET=

# Fake local fixture mode values.
MONEYSIREN_AWS_COST_EXPLORER_FIXTURE=tests/fixtures/providers/aws/cost-explorer-grouped-by-service.json
MONEYSIREN_OPENAI_USAGE_FIXTURE=tests/fixtures/providers/openai/usage-costs.json
MONEYSIREN_OPENAI_COSTS_FIXTURE=tests/fixtures/providers/openai/usage-costs.json
MONEYSIREN_SUPABASE_FIXTURE=tests/fixtures/providers/supabase/usage-health.json
MONEYSIREN_CLOUDFLARE_FIXTURE=tests/fixtures/providers/cloudflare/billing-usage.json
