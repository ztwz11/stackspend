# StackSpend v0.1 uses env-only secrets.
# Never commit real API keys, tokens, webhook URLs, or provider identifiers.
# Keep secret values blank here. Export real values only in your shell for one run.

AWS_PROFILE=
OPENAI_ADMIN_KEY=
SUPABASE_ACCESS_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_IDS=
SLACK_WEBHOOK_URL=
STACKSPEND_DB_PATH=.stackspend/stackspend.sqlite
STACKSPEND_SQLITE_BIN=
STACKSPEND_TIMEZONE=

# Optional local web credential store.
# Leave secrets blank in this example. Prefer OS keychain; use vault only for local runs where keychain is unavailable.
STACKSPEND_CREDENTIAL_BACKEND=
STACKSPEND_CREDENTIAL_VAULT_PATH=
STACKSPEND_CREDENTIAL_VAULT_PASSPHRASE=

# Optional local OAuth broker settings. Client IDs and endpoints are operator-local config, not provider secrets.
SUPABASE_OAUTH_AUTHORIZATION_URL=
SUPABASE_OAUTH_CLIENT_ID=

# Fake local fixture mode values.
STACKSPEND_AWS_COST_EXPLORER_FIXTURE=tests/fixtures/providers/aws/cost-explorer-grouped-by-service.json
STACKSPEND_OPENAI_USAGE_FIXTURE=tests/fixtures/providers/openai/usage-costs.json
STACKSPEND_OPENAI_COSTS_FIXTURE=tests/fixtures/providers/openai/usage-costs.json
STACKSPEND_SUPABASE_FIXTURE=tests/fixtures/providers/supabase/usage-health.json
STACKSPEND_CLOUDFLARE_FIXTURE=tests/fixtures/providers/cloudflare/billing-usage.json
